@page
@model IndexModel
@{
    ViewData["Title"] = "Secure Notes";
}

<div class="secure-notes-container">
    <header class="page-header">
        <h1>Secure Notes</h1>
        <p class="subtitle">Encrypt and decrypt your sensitive text securely</p>
    </header>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error" role="alert" aria-live="polite">
            <svg class="alert-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                 aria-hidden="true">
                <path fill-rule="evenodd"
                      d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z"
                      clip-rule="evenodd"/>
            </svg>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <div class="ci-cd-test">
        <p><strong>CI/CD Test:</strong> This is a test message to verify the CI/CD pipeline is functioning correctly.
        </p>
    </div>

    <div class="crypto-grid">
        <!-- Encryption Section -->
        <section class="crypto-card" aria-labelledby="encryption-heading">
            <h2 id="encryption-heading" class="card-title">
                <svg class="title-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                     aria-hidden="true">
                    <path fill-rule="evenodd"
                          d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z"
                          clip-rule="evenodd"/>
                </svg>
                Encryption
            </h2>

            <form method="post" asp-page-handler="Encrypt" class="crypto-form">
                <div class="form-group">
                    <label asp-for="InputText" class="form-label">
                        Enter Text to Encrypt
                        <span class="required" aria-label="required">*</span>
                    </label>
                    <textarea
                        asp-for="InputText"
                        class="form-control"
                        rows="3"
                        required
                        aria-required="true"
                        aria-describedby="input-text-help"
                        placeholder="Type your sensitive text here..."></textarea>
                    <small id="input-text-help" class="form-text">Your text will be encrypted using AES-256</small>
                </div>

                <button type="submit" class="btn btn-primary">
                    <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                         aria-hidden="true">
                        <path fill-rule="evenodd"
                              d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z"
                              clip-rule="evenodd"/>
                    </svg>
                    Encrypt Text
                </button>

                @if (!string.IsNullOrEmpty(Model.EncryptedText))
                {
                    <div class="form-group result-group">
                        <label asp-for="EncryptedText" class="form-label">Encrypted Result</label>
                        <textarea
                            asp-for="EncryptedText"
                            class="form-control result-field"
                            readonly
                            aria-readonly="true"
                            aria-describedby="encrypted-text-help"></textarea>
                        <small id="encrypted-text-help" class="form-text success">✓ Text successfully encrypted</small>
                    </div>
                }
            </form>
        </section>

        <!-- Decryption Section -->
        <section class="crypto-card" aria-labelledby="decryption-heading">
            <h2 id="decryption-heading" class="card-title">
                <svg class="title-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                     aria-hidden="true">
                    <path
                        d="M10 2a5 5 0 00-5 5v2a2 2 0 00-2 2v5a2 2 0 002 2h10a2 2 0 002-2v-5a2 2 0 00-2-2H7V7a3 3 0 015.905-.75 1 1 0 001.937-.5A5.002 5.002 0 0010 2z"/>
                </svg>
                Decryption
            </h2>

            <form method="post" asp-page-handler="Decrypt" class="crypto-form">
                <div class="form-group">
                    <label asp-for="EncryptedInputText" class="form-label">
                        Enter Encrypted Text
                        <span class="required" aria-label="required">*</span>
                    </label>
                    <textarea
                        asp-for="EncryptedInputText"
                        class="form-control"
                        rows="3"
                        required
                        aria-required="true"
                        aria-describedby="encrypted-input-help"
                        placeholder="Paste your encrypted text here..."></textarea>
                    <small id="encrypted-input-help" class="form-text">Paste the Base64-encoded encrypted text</small>
                </div>

                <button type="submit" class="btn btn-secondary">
                    <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                         aria-hidden="true">
                        <path
                            d="M10 2a5 5 0 00-5 5v2a2 2 0 00-2 2v5a2 2 0 002 2h10a2 2 0 002-2v-5a2 2 0 00-2-2H7V7a3 3 0 015.905-.75 1 1 0 001.937-.5A5.002 5.002 0 0010 2z"/>
                    </svg>
                    Decrypt Text
                </button>

                @if (!string.IsNullOrEmpty(Model.DecryptedText))
                {
                    <div class="form-group result-group">
                        <label asp-for="DecryptedText" class="form-label">Decrypted Result</label>
                        <textarea
                            asp-for="DecryptedText"
                            class="form-control result-field"
                            readonly
                            aria-readonly="true"
                            aria-describedby="decrypted-text-help"></textarea>
                        <small id="decrypted-text-help" class="form-text success">✓ Text successfully decrypted</small>
                    </div>
                }
            </form>
        </section>
    </div>
</div>
